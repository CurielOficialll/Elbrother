{
  "name": "elbrother-pos",
  "version": "2.5.5",
  "description": "Sistema Elbrother POS - Inventario y Punto de Venta Local",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.curieloficialll.elbrother",
    "productName": "Elbrother POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!data/**/*",
      "!mockups/**/*",
      "!*.md",
      "!implementation_plan.md",
      "!task.md",
      "!walkthrough.md"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "velopack": "^0.0.1589-ga2c5a97"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
